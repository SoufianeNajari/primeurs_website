# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connexion Postgres directe — uniquement pour `npm run db:migrate`.
# Supabase Dashboard > Project Settings > Database > Connection string (URI)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_DB_URL=

# ─── Email ───────────────────────────────────────────────────
RESEND_API_KEY=
MAILTRAP_USER=
MAILTRAP_PASS=
SHOP_EMAIL=
# Adresse d'expéditeur Resend. À configurer SUR UN DOMAINE VÉRIFIÉ avant
# la prod. Tant que vide, fallback sur "Primeur Chez Vous <onboarding@resend.dev>"
# qui n'envoie qu'à l'adresse créatrice du compte Resend → en prod, les clients
# ne recevront AUCUN email de confirmation.
RESEND_FROM=

# ─── Admin ───────────────────────────────────────────────────
ADMIN_PASSWORD=
# Secret de signature du cookie admin (min 32 caractères).
# Génération recommandée : openssl rand -base64 32
ADMIN_SESSION_SECRET=

# ─── Site ────────────────────────────────────────────────────
# URL publique (sans slash final). Utilisée pour SEO (sitemap, OG, JSON-LD).
# À renseigner avec le domaine custom une fois acheté. Laisser vide en
# attendant : la cascade Vercel (VERCEL_PROJECT_PRODUCTION_URL, VERCEL_URL,
# puis localhost) prend le relais automatiquement. Ne PAS y mettre
# `pontaultprimeurs.fr` — le code l'ignore mais c'est trompeur.
NEXT_PUBLIC_SITE_URL=

# ─── Secrets HMAC ────────────────────────────────────────────
# Signe les liens d'annulation J-1 envoyés par email. Génération :
#   openssl rand -hex 32
# Tant que vide, le code retombe sur SUPABASE_SERVICE_ROLE_KEY avec warning :
# à configurer en prod pour pouvoir rotater indépendamment.
ORDER_CANCEL_SECRET=

# Bearer requis par les cron Vercel (/api/cron/*). Génération :
#   openssl rand -hex 32
CRON_SECRET=

# ─── Google Places (avis clients) ────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
