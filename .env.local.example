# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connexion Postgres directe — uniquement pour `npm run db:migrate`.
# Supabase Dashboard > Project Settings > Database > Connection string (URI)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_DB_URL=

# ─── Email ───────────────────────────────────────────────────
RESEND_API_KEY=
MAILTRAP_USER=
MAILTRAP_PASS=
SHOP_EMAIL=

# ─── Admin ───────────────────────────────────────────────────
ADMIN_PASSWORD=

# ─── Site ────────────────────────────────────────────────────
# URL publique (sans slash final). Utilisée pour SEO (sitemap, OG, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://pontaultprimeurs.fr

# ─── Google Places (avis clients) ────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
